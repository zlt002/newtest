    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^12.9.0",
    "canvg": "^4.0.3",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
