{
  "name": "@cloudcli-ai/cloudcli",
  "version": "1.28.0",
  "description": "A web-based UI for Claude Code CLI",
  "type": "module",
  "main": "server/index.js",
  "bin": {
    "ccui": "server/cli.js"
  },
  "files": [
    "server/",
    "shared/",
    "dist/",
    "scripts/",
    "README.md"
  ],
  "scripts": {
    "check:claude-agent-sdk-version": "node scripts/check-claude-agent-sdk-version.mjs",
    "dev": "concurrently --kill-others \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "node --max-old-space-size=8192 ./node_modules/vite/bin/vite.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --experimental-strip-types --experimental-specifier-resolution=node --test \"shared/claudeCommandRegistry.test.mjs\" \"server/agent-v2/runtime/claude-v2-sdk-contract.test.mjs\" \"server/providers/types.test.mjs\" \"server/routes/cli-auth.test.mjs\" \"server/routes/projects.test.mjs\" \"server/utils/ask-user-question.test.mjs\" \"server/utils/claude-code-runtime.test.mjs\" \"server/utils/claude-latency-trace.test.mjs\" \"server/utils/claude-sdk-error.test.mjs\" \"server/utils/claude-session.test.mjs\" \"server/utils/langsmith-claude-sdk.test.mjs\" \"server/utils/projects-watcher.test.mjs\" \"server/utils/symbol-dispose-polyfill.test.mjs\" \"server/utils/todo-write.test.mjs\" \"scripts/legacy-agent-sdk-cleanup.test.mjs\" \"src/i18n/tasks.locale.test.mjs\" \"src/contexts/WebSocketContext.test.mjs\" \"src/components/chat/hooks/builtInCommandBehavior.test.mjs\" \"src/components/chat/hooks/chatComposerSessionTarget.test.mjs\" \"src/components/chat/hooks/chatSessionViewState.test.mjs\" \"src/components/chat/hooks/sessionTranscript.test.mjs\" \"src/components/chat/hooks/slashCommandData.test.mjs\" \"src/components/chat/hooks/slashCommandSelection.test.mjs\" \"src/components/chat/hooks/useChatSessionState.test.mjs\" \"src/components/chat/tools/components/subagentProgressView.test.mjs\" \"src/components/chat/utils/chatPermissions.test.mjs\" \"src/components/chat/utils/latencyTrace.test.mjs\" \"src/components/chat/view/agentConversationContext.test.mjs\" \"src/components/chat/view/agentV2Realtime.test.mjs\" \"src/components/chat/view/subcomponents/ChatInputControls.test.mjs\" \"src/components/chat/view/subcomponents/ChatMessagesPane.test.mjs\" \"src/components/chat/view/subcomponents/commandMenuGroups.test.mjs\" \"src/components/chat/view/subcomponents/messageCollapse.test.mjs\" \"src/components/chat/view/subcomponents/Markdown.link-routing.test.mjs\" \"src/components/chat/view/subcomponents/MessageComponent.jobTree.test.mjs\" \"src/components/settings/view/tabs/agents-settings/sections/content/PermissionsContent.claude.test.mjs\" \"src/components/sidebar/utils/utils.test.mjs\" \"src/components/sidebar/utils/sidebarFolderDrop.test.mjs\" \"src/components/sidebar/view/subcomponents/sidebarWorkspace.test.mjs\" \"src/components/code-editor/utils/editorSidebarLayout.test.mjs\" \"src/components/code-editor/utils/editorSidebarPersistence.test.mjs\" \"src/components/code-editor/hooks/editorSidebarUrlOpenState.test.mjs\" \"src/components/right-pane/utils/htmlPreviewTarget.test.mjs\" \"src/components/right-pane/utils/browserPaneState.test.mjs\" \"src/components/right-pane/utils/browserEmbedFallback.test.mjs\" \"src/components/right-pane/utils/rightPaneTargetIdentity.test.mjs\" \"src/components/right-pane/utils/rightPaneVisibleTabs.test.mjs\" \"src/components/right-pane/view/RightPane.source.test.mjs\" \"src/components/file-tree/view/FileTreeExplorerButton.test.mjs\" \"src/components/file-tree/view/FileTreeNode.test.mjs\" \"src/components/file-tree/view/FileTreeViewMode.test.mjs\" \"src/components/file-tree/utils/fileOpenPayload.test.mjs\" \"src/hooks/useProjectsRouteSelection.test.mjs\" \"src/types/app.test.mjs\" \"src/index.css.test.mjs\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "release:windows-lite": "node scripts/build-release.mjs && node scripts/prepare-release-node-modules.mjs && node scripts/prune-release-node-modules.mjs && node scripts/verify-release.mjs",
    "release:windows-lite:x64": "set \"WINDOWS_LITE_TARGET_ARCH=x64\" && node scripts/build-release.mjs && node scripts/prepare-release-node-modules.mjs && node scripts/prune-release-node-modules.mjs && node scripts/verify-release.mjs",
    "release:windows-lite:x64:zip": "npm run release:windows-lite:x64 && node scripts/archive-release.mjs --target=x64",
    "verify:release": "node scripts/verify-release.mjs",
    "start": "npm run build && npm run server"
  },
  "author": "CC UI",
  "license": "AGPL-3.0-or-later",
