# repowise 自定义 API 配置
# 复制此文件到你的项目目录并命名为 .env

# ---------------------------------------------------------------------------
# LLM Provider - 使用 Anthropic 兼容接口
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-12l-SQhlcW7g5GII6BuQVg
ANTHROPIC_BASE_URL=https://anapi-uat.annto.com/api-sse-anthropic/v1

# ---------------------------------------------------------------------------
# Embedding Provider - 使用阿里云百炼 (OpenAI 兼容接口)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-803750372bed4b419069f57ca7fd0f86
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ---------------------------------------------------------------------------
# 默认配置
# ---------------------------------------------------------------------------
REPOWISE_DEFAULT_PROVIDER=anthropic
REPOWISE_DEFAULT_MODEL=minimax-m2.7-highspeed
REPOWISE_EMBEDDER=openai

# ---------------------------------------------------------------------------
# 其他配置 (可选)
# ---------------------------------------------------------------------------
REPOWISE_MAX_CONCURRENT=5
REPOWISE_LOG_LEVEL=INFO
